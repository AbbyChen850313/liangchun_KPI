rules_version = '2';

// All collections are managed exclusively through the backend API via Admin SDK.
// Admin SDK bypasses these rules entirely, so denying all direct client access
// is safe and prevents accidental data exposure or tampering from the browser.
// KPI access control (employee/manager/HR) is enforced at the Flask API layer.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
